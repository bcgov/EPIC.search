# EPIC Search MCP Server Configuration

# Vector Search API Configuration
VECTOR_SEARCH_API_URL=https://your-vector-api.azurewebsites.net/api

# Server Configuration
MCP_SERVER_NAME=epic-search-tools
MCP_SERVER_VERSION=1.0.0

# Logging Configuration
LOG_LEVEL=INFO

# Tool Configuration
MAX_SEARCH_RESULTS=50
DEFAULT_SEARCH_LIMIT=10

# Timeout Configuration (in seconds)
API_TIMEOUT=300

# Environment
ENVIRONMENT=production

# Azure App Service specific (automatically set by Azure)
# WEBSITES_PORT=8000
# WEBSITES_ENABLE_APP_SERVICE_STORAGE=false
